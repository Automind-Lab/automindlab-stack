{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://automindlab.dev/schemas/operator-command-policy.schema.json",
  "title": "Operator Command Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "defaultMode",
    "capabilities",
    "safeCommandExact",
    "blockedCommandTokens"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "defaultMode": {
      "type": "string",
      "enum": ["allow", "prompt", "deny"]
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "enum": ["allow", "prompt", "deny"]
      }
    },
    "safeCommandExact": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blockedCommandTokens": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
