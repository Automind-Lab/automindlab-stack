{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://automindlab.local/schemas/browser-research-result.schema.json",
  "title": "Browser Research Result",
  "type": "object",
  "required": ["goal", "visited", "findings", "uncertainty", "escalate"],
  "properties": {
    "goal": {"type": "string"},
    "visited": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url", "title"],
        "properties": {
          "url": {"type": "string"},
          "title": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim", "evidence"],
        "properties": {
          "claim": {"type": "string"},
          "evidence": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "uncertainty": {"type": "string", "enum": ["low", "medium", "high"]},
    "escalate": {"type": "boolean"}
  },
  "additionalProperties": false
}
