{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://automindlab.dev/schemas/enterprise-app-design-handoff.schema.json",
  "title": "Enterprise App Design Handoff",
  "type": "object",
  "additionalProperties": false,
  "required": ["generatedAt", "themeConfig", "tokens", "componentManifest", "screenMap", "copyMap", "figmaAdapter"],
  "properties": {
    "generatedAt": { "type": "string" },
    "themeConfig": {
      "type": "object",
      "required": ["brandName", "primaryColor", "secondaryColor", "accentColor", "surfaceColor", "canvasColor"],
      "properties": {
        "brandName": { "type": "string" },
        "primaryColor": { "type": "string" },
        "secondaryColor": { "type": "string" },
        "accentColor": { "type": "string" },
        "surfaceColor": { "type": "string" },
        "canvasColor": { "type": "string" }
      }
    },
    "tokens": { "type": "array", "items": { "type": "object" } },
    "componentManifest": { "type": "array", "items": { "type": "object" } },
    "screenMap": { "type": "array", "items": { "type": "object" } },
    "copyMap": { "type": "array", "items": { "type": "object" } },
    "figmaAdapter": {
      "type": "object",
      "required": ["enabled", "mode", "importContract", "exportContract"],
      "properties": {
        "enabled": { "type": "boolean" },
        "mode": { "type": "string" },
        "importContract": { "type": "string" },
        "exportContract": { "type": "string" }
      }
    }
  }
}
