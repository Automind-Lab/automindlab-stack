{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://automindlab.dev/schemas/capability-intake-catalog.schema.json",
  "title": "Capability Intake Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "catalogVersion",
    "catalogId",
    "reviewStatus",
    "description",
    "entries"
  ],
  "properties": {
    "catalogVersion": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}\\.v\\d+$"
    },
    "catalogId": {
      "type": "string",
      "minLength": 1
    },
    "reviewStatus": {
      "type": "string",
      "enum": ["candidate", "approved", "rejected"]
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entry"
      }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "sourceRepoOrSource",
        "capabilityType",
        "adoptionMode",
        "owner",
        "riskLevel",
        "networkScope",
        "storageScope",
        "secretScope",
        "tenantScope",
        "rolloutRing",
        "approvalRequirements",
        "rollbackNotes",
        "reviewNotes",
        "enterpriseJustification",
        "boundaryDecision",
        "decisionDate",
        "decisionOwner"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "sourceRepoOrSource": {
          "type": "string",
          "minLength": 1
        },
        "capabilityType": {
          "type": "string",
          "enum": ["tool", "skill", "source-repo", "workflow-pattern", "service-surface"]
        },
        "adoptionMode": {
          "type": "string",
          "enum": ["wrap", "curate", "inspire", "reject"]
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "riskLevel": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "networkScope": {
          "type": "string",
          "enum": ["none", "operator-approved", "api-read", "api-write", "external-web"]
        },
        "storageScope": {
          "type": "string",
          "enum": ["none", "repo-only", "runtime-config", "service-contracts", "downstream-owned"]
        },
        "secretScope": {
          "type": "string",
          "enum": ["none", "operator-provided", "runtime-secrets", "downstream-secrets"]
        },
        "tenantScope": {
          "type": "string",
          "enum": ["single-tenant", "platform-shared", "downstream-owned"]
        },
        "rolloutRing": {
          "type": "string",
          "enum": ["design", "sandbox", "staging", "production"]
        },
        "approvalRequirements": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rollbackNotes": {
          "type": "string",
          "minLength": 1
        },
        "reviewNotes": {
          "type": "string",
          "minLength": 1
        },
        "enterpriseJustification": {
          "type": "string",
          "minLength": 1
        },
        "boundaryDecision": {
          "type": "string",
          "minLength": 1
        },
        "decisionDate": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "decisionOwner": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
