{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://automindlab.local/schemas/downstream-sync-manifest.schema.json",
  "title": "Downstream Sync Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "consumer",
    "mode",
    "contract_version",
    "review_paths",
    "default_skip_paths",
    "sync_rules",
    "notes"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "consumer": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": [
        "manual_review_only"
      ]
    },
    "contract_version": {
      "type": "string",
      "pattern": "^20[0-9]{2}-[0-9]{2}-[0-9]{2}\\.v[0-9]+$"
    },
    "review_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "default_skip_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "sync_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
