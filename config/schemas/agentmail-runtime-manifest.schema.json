{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://automindlab.dev/schemas/agentmail-runtime-manifest.schema.json",
  "title": "AgentMail Runtime Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifestVersion",
    "manifestId",
    "provider",
    "description",
    "requiredEnv",
    "domains",
    "mailboxes",
    "webhooks",
    "serviceSurfaces",
    "approvalBoundaries",
    "notes"
  ],
  "properties": {
    "manifestVersion": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}\\.v\\d+$"
    },
    "manifestId": {
      "type": "string",
      "pattern": "^[a-z0-9.-]+$"
    },
    "provider": {
      "type": "string",
      "const": "agentmail"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "requiredEnv": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "domains": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/domain"
      }
    },
    "mailboxes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/mailbox"
      }
    },
    "webhooks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/webhook"
      }
    },
    "serviceSurfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/serviceSurface"
      }
    },
    "approvalBoundaries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "domain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "domain",
        "purpose",
        "routingMode",
        "evidenceStatus",
        "ownerSurface",
        "requiredOperations",
        "notes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "domain": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "routingMode": {
          "type": "string",
          "enum": ["shared-hosted", "custom-domain"]
        },
        "evidenceStatus": {
          "type": "string",
          "enum": ["planned", "user-declared", "api-validated", "dns-validated", "runtime-validated"]
        },
        "ownerSurface": {
          "type": "string",
          "enum": ["host", "worker", "downstream", "shared"]
        },
        "requiredOperations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "mailbox": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "address",
        "purpose",
        "role",
        "ownerSurface",
        "approvalMode",
        "evidenceStatus",
        "domainRef",
        "allowedOperations",
        "requiredScopes",
        "notes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "address": {
          "type": "string",
          "pattern": "^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$"
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "enum": ["operator-primary", "operator-secondary", "runtime-agent", "downstream-agent", "notification"]
        },
        "ownerSurface": {
          "type": "string",
          "enum": ["host", "worker", "downstream", "shared"]
        },
        "approvalMode": {
          "type": "string",
          "enum": ["allow", "prompt", "deny"]
        },
        "evidenceStatus": {
          "type": "string",
          "enum": ["planned", "user-declared", "api-validated", "dns-validated", "runtime-validated"]
        },
        "domainRef": {
          "type": ["string", "null"],
          "pattern": "^[a-z0-9-]+$"
        },
        "allowedOperations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requiredScopes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "webhook": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "eventTypes",
        "targetSurface",
        "deliveryMode",
        "evidenceStatus",
        "notes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "eventTypes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "targetSurface": {
          "type": "string",
          "minLength": 1
        },
        "deliveryMode": {
          "type": "string",
          "enum": ["planned", "push", "pull"]
        },
        "evidenceStatus": {
          "type": "string",
          "enum": ["planned", "user-declared", "api-validated", "dns-validated", "runtime-validated"]
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "serviceSurface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "type",
        "manifestPath",
        "requestSchema",
        "responseSchema",
        "owner",
        "advisoryOnly"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["runtime-contract", "operator-contract"]
        },
        "manifestPath": {
          "type": "string",
          "minLength": 1
        },
        "requestSchema": {
          "type": ["string", "null"]
        },
        "responseSchema": {
          "type": ["string", "null"]
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "advisoryOnly": {
          "type": "boolean"
        }
      }
    }
  }
}
