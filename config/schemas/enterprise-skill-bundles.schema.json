{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://automindlab.dev/schemas/enterprise-skill-bundles.schema.json",
  "title": "Enterprise Skill Bundles",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "catalog_name",
    "description",
    "bundles"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "catalog_name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "bundles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/bundle"
      }
    }
  },
  "$defs": {
    "bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "purpose",
        "skills",
        "when_to_use",
        "guardrails"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        },
        "skills": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "when_to_use": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "guardrails": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
