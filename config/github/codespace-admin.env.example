# Copy this file to config/github/codespace-admin.env and fill in local values.

AUTOMIND_AUTONOMY_EXECUTION_ENABLED=false
AUTOMIND_WORKSPACE_SYNC_ENABLED=false
AUTOMINDLAB_GITHUB_AUTONOMY_EXECUTOR=/absolute/path/to/automindlab-github-executor
AUTOMIND_HOST_WORKSPACE=$HOME/.openclaw/workspace-automind-host
AUTOMIND_WORKER_WORKSPACE=$HOME/.openclaw/workspace-automind-worker
OPENCLAW_HOME=$HOME/.openclaw
